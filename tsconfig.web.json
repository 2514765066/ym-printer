{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/**/*",
    "src/preload/index.d.ts",
    "src/shared/type.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@/*": ["./src/renderer/src/*"],
      "@type": ["./src/shared/type.ts"]
    }
  }
}
